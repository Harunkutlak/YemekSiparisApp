@{
    ViewData["Title"] = "Bağış Yap";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div style="font-size:3rem;">💚</div>
                        <h3>Askıda Yemek'e Destek Ol</h3>
                        <p class="text-muted">Bağışınız doğrudan ihtiyaç sahiplerinin hesaplarına tanımlanır.</p>
                    </div>

                    <form asp-action="Bagis" method="post">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="mb-4">
                            <label class="form-label fw-bold">Bağış Miktarı (₺)</label>
                            <input type="number" name="miktar" class="form-control form-control-lg" min="1" step="0.5" required placeholder="Örn: 100" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Bağış Mesajı (İsteğe Bağlı)</label>
                            <textarea name="mesaj" class="form-control" rows="3" placeholder="İhtiyaç sahiplerine iletmek istediğiniz bir not var mı?"></textarea>
                        </div>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="isAnonim" name="isAnonim" value="true">
                                <label class="form-check-label" for="isAnonim">İsmimi gizle (Anonim Bağış)</label>
                            </div>
                        }
                        else
                        {
                            <!-- Giriş yapılmamışsa mecburen anonim -->
                            <input type="hidden" name="isAnonim" value="true" />
                            <div class="alert alert-info py-2">
                                <small>Giriş yapmadığınız için bağışınız anonim olarak kaydedilecektir.</small>
                            </div>
                        }

                        <button type="submit" class="btn btn-success btn-lg w-100" style="background-color: #10b981; border:none;">
                            Bağışı Gönder
                        </button>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>
