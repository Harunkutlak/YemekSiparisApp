@model YemekSiparisApp.Models.Entities.AskidaYemekHavuzu
@{
    ViewData["Title"] = "Askıda Yemek Havuzu";
}

<div class="container my-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            @if (TempData["Mesaj"] != null)
            {
                <div class="alert alert-success">@TempData["Mesaj"]</div>
            }

            <div class="text-center mb-4">
                <h2>💛 @Model.Ad</h2>
                <p class="text-muted">@Model.Aciklama</p>
                
                <div class="askida-stats d-inline-block mt-3" style="background:#10b981; color:white; padding: 20px 40px; border-radius: 12px;">
                    <div style="font-size: 3rem; font-weight: bold;">₺@Model.ToplamBakiye.ToString("N2")</div>
                    <div>Güncel Havuz Bakiyesi</div>
                </div>
                
                <div class="mt-4">
                    <a asp-action="Bagis" class="btn btn-lg btn-success">💚 Hemen Bağış Yap</a>
                </div>
            </div>

            <hr />
            
            <h4 class="mt-4">Son Bağışlar</h4>
            @if (ViewBag.SonBagislar != null && ((IEnumerable<dynamic>)ViewBag.SonBagislar).Any())
            {
                <ul class="list-group">
                    @foreach (var bagis in ViewBag.SonBagislar)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@(bagis.IsAnonim || bagis.BagisciKullanici == null ? "Anonim Hayırsever" : bagis.BagisciKullanici.Ad + " " + bagis.BagisciKullanici.Soyad)</strong>
                                <br />
                                <small class="text-muted">@bagis.BagisTarihi.ToString("dd MMM yyyy HH:mm")</small>
                                @if (!string.IsNullOrEmpty(bagis.Mesaj))
                                {
                                    <div class="fst-italic text-secondary mt-1">"@bagis.Mesaj"</div>
                                }
                            </div>
                            <span class="badge bg-success rounded-pill" style="font-size:1.1rem;">+₺@bagis.Miktar.ToString("N2")</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Henüz bağış hareketi bulunmuyor. İlk bağış yapan siz olun!</p>
            }
        </div>
    </div>
</div>
