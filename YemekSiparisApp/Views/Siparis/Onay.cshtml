@model YemekSiparisApp.Models.ViewModels.SiparisOnayViewModel
@{
    ViewData["Title"] = "Sipariş Onayı";
}

<div class="container section">
    <div style="max-width: 600px; margin: 0 auto;">
        <h2 style="margin-bottom: 20px; text-align:center;">Sipariş Onayı</h2>

        <form asp-action="Onay" method="post">
            <div asp-validation-summary="ModelOnly" style="color: #ef4444; background: rgba(239, 68, 68, 0.1); padding: 15px; border-radius: 8px; margin-bottom: 20px;"></div>

            <div class="card" style="padding: 20px; margin-bottom: 20px; background: var(--bg-card);">
                <div class="form-group" style="margin-bottom: 15px;">
                    <label asp-for="TeslimatAdresi" style="display:block; margin-bottom:8px; font-weight:600;">Teslimat Adresi</label>
                    <textarea asp-for="TeslimatAdresi" rows="3" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border); background:var(--bg-card2); color:white;" placeholder="Adresinizi yazınız..."></textarea>
                    <span asp-validation-for="TeslimatAdresi" style="color:#ef4444; font-size:0.8rem;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SiparisNotu" style="display:block; margin-bottom:8px; font-weight:600;">Sipariş Notu</label>
                    <input asp-for="SiparisNotu" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border); background:var(--bg-card2); color:white;" placeholder="Opsiyonel (Zili çalmayın vb.)" />
                </div>
            </div>

            <div class="card" style="padding: 20px; border: 2px solid #fcd34d; background: rgba(252, 211, 77, 0.05); margin-bottom: 20px;">
                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer;">
                    <input type="checkbox" asp-for="AskidaYemekKullan" style="width: 30px; height: 30px; accent-color: #fcd34d; cursor:pointer;" />
                    <div style="font-weight: bold; color: #fcd34d; font-size: 1.1rem;">
                        🆘 Bu siparişi Askıda Yemek fonundan ücretsiz almak istiyorum
                    </div>
                </label>
                <div style="font-size: 0.85rem; color: #94a3b8; margin-top: 10px; margin-left: 45px; line-height:1.4;">
                    • Talebiniz Admin onayına gidecektir.<br/>
                    • Onaylandıktan sonra restoran hazırlığa başlar.<br/>
                    • Aylık limitiniz 500 TL'dir.
                </div>
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; padding: 18px; font-size: 1.25rem; font-weight:bold; border-radius:12px; cursor:pointer;">
                Siparişi Onayla ve Gönder →
            </button>
        </form>
    </div>
</div>
