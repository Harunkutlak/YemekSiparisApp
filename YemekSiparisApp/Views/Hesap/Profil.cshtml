@model YemekSiparisApp.Models.ViewModels.ProfilViewModel
@{
    ViewData["Title"] = "Profilim";
    var rolAdi = Model.Rol switch {
        "Musteri" => "Müşteri",
        "Admin" => "Admin",
        "RestoranSahibi" => "Restoran Sahibi",
        "Kurye" => "Kurye",
        _ => Model.Rol
    };
}

<style>
    .profil-layout {
        max-width: 960px;
        margin: 40px auto;
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 28px;
        align-items: start;
    }

    /* ── Sol kart: Kimlik bilgileri ── */
    .profil-sidebar {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px 24px;
        text-align: center;
    }
    .profil-avatar {
        width: 88px; height: 88px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary) 0%, #ff8c5a 100%);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.2rem;
        margin: 0 auto 16px;
        box-shadow: 0 8px 24px rgba(255,90,31,0.3);
    }
    .profil-name {
        font-size: 1.15rem; font-weight: 700;
        color: var(--text-primary); margin-bottom: 6px;
    }
    .profil-email {
        font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;
        word-break: break-all;
    }
    .profil-role-badge {
        display: inline-block; padding: 5px 14px;
        border-radius: 20px; font-size: 0.8rem; font-weight: 600;
        background: rgba(255,90,31,0.12); color: var(--primary);
        border: 1px solid rgba(255,90,31,0.25);
        margin-bottom: 24px;
    }
    .profil-stat {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 0;
        border-top: 1px solid var(--border);
        font-size: 0.88rem;
    }
    .profil-stat .label { color: var(--text-muted); }
    .profil-stat .val { font-weight: 600; color: var(--text-primary); }

    /* ── Sağ kart: Form ── */
    .profil-form-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }
    .profil-form-header {
        padding: 20px 28px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 12px;
    }
    .profil-form-header h2 {
        margin: 0; font-size: 1.1rem; font-weight: 700;
    }
    .profil-form-body { padding: 28px; }

    .section-title {
        font-size: 0.78rem; font-weight: 700; color: var(--primary);
        text-transform: uppercase; letter-spacing: 0.8px;
        margin-bottom: 16px; margin-top: 28px;
        display: flex; align-items: center; gap: 8px;
    }
    .section-title:first-child { margin-top: 0; }
    .section-title::after {
        content: ''; flex: 1; height: 1px; background: var(--border);
    }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-grid.full { grid-template-columns: 1fr; }

    .field { margin-bottom: 0; }
    .field label {
        display: block; font-size: 0.83rem; font-weight: 600;
        color: var(--text-muted); margin-bottom: 7px;
    }
    .field input {
        width: 100%; padding: 11px 14px; border-radius: 10px;
        border: 1.5px solid var(--border); background: var(--bg-card2);
        color: var(--text-primary); font-size: 0.9rem; outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .field input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(255,90,31,0.12);
    }
    .field input[readonly] {
        opacity: 0.55; cursor: not-allowed;
        border-style: dashed;
    }
    .field .hint {
        font-size: 0.75rem; color: var(--text-muted); margin-top: 5px;
    }
    .field-error {
        font-size: 0.78rem; color: #f87171; margin-top: 4px;
    }

    .sifre-toggle-section {
        background: rgba(255,90,31,0.04);
        border: 1px solid rgba(255,90,31,0.15);
        border-radius: 12px;
        padding: 18px 20px;
        margin-top: 4px;
    }
    .sifre-toggle-btn {
        background: none; border: none; cursor: pointer;
        color: var(--primary); font-size: 0.9rem; font-weight: 600;
        padding: 0; display: flex; align-items: center; gap: 8px;
        transition: opacity 0.2s;
    }
    .sifre-toggle-btn:hover { opacity: 0.75; }
    .sifre-fields { display: none; margin-top: 16px; }
    .sifre-fields.open { display: grid; grid-template-columns: 1fr; gap: 14px; }

    .profil-form-footer {
        padding: 20px 28px;
        border-top: 1px solid var(--border);
        display: flex; justify-content: flex-end; gap: 12px;
    }
    .btn-save {
        padding: 12px 28px; border-radius: 10px;
        background: var(--primary); border: none;
        color: white; cursor: pointer; font-weight: 700;
        font-size: 0.95rem; transition: all 0.2s;
        display: flex; align-items: center; gap: 8px;
    }
    .btn-save:hover { background: var(--primary-hover); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(255,90,31,0.3); }
    .btn-cancel-link {
        padding: 12px 20px; border-radius: 10px;
        border: 1.5px solid var(--border); background: transparent;
        color: var(--text-muted); cursor: pointer; font-weight: 600;
        text-decoration: none; font-size: 0.9rem; transition: all 0.2s;
        display: flex; align-items: center;
    }
    .btn-cancel-link:hover { background: rgba(255,255,255,0.04); }

    @@media (max-width: 700px) {
        .profil-layout { grid-template-columns: 1fr; }
        .form-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="profil-layout">

    <!-- ═══ Sol: Kimlik Kartı ═══ -->
    <div class="profil-sidebar">
        <div class="profil-avatar">👤</div>
        <div class="profil-name">@Model.Ad @Model.Soyad</div>
        <div class="profil-email">@Model.Email</div>
        <div class="profil-role-badge">@rolAdi</div>

        @{
            var basvuru = ViewBag.Basvuru as YemekSiparisApp.Models.Entities.AskidaYemekBasvuru;
            var kullanici = Model;
        }

        <!-- Askıda Yemek Başvuru Kartı (sadece Müşteri rolü için) -->
        @if (Model.Rol == "Musteri") {
            <div style="margin-top: 20px; border-top: 1px solid var(--border); padding-top: 20px; text-align: left;">
                <div style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 12px;">
                    💛 Askıda Yemek
                </div>

                @if (basvuru == null) {
                    <!-- Hiç başvuru yok -->
                    <p style="font-size: 0.82rem; color: var(--text-muted); margin-bottom: 12px; line-height: 1.5;">
                        Maddi güçlük yaşıyorsanız Askıda Yemek programından ücretsiz sipariş verebilirsiniz.
                        Admin onayı gereklidir.
                    </p>
                    <button onclick="document.getElementById('basvuruForm').style.display='block'; this.style.display='none';"
                        style="width:100%; padding:10px; border-radius:10px; border: 1.5px solid rgba(255,210,50,0.3); background:rgba(255,210,50,0.08); color:#fcd34d; font-size:0.88rem; font-weight:700; cursor:pointer; transition: all 0.2s;">
                        📋 Başvuru Yap
                    </button>
                    <form id="basvuruForm" asp-action="Basvur" method="post" style="display:none; margin-top:12px;">
                        @Html.AntiForgeryToken()
                        <textarea name="basvuruNotu" rows="3" placeholder="Başvuru nedeninizi kısaca açıklayabilirsiniz (opsiyonel)..."
                            style="width:100%; padding:10px; border-radius:8px; border:1.5px solid var(--border); background:var(--bg-card2); color:var(--text-primary); font-size:0.82rem; resize:none; outline:none; margin-bottom:8px;"></textarea>
                        <button type="submit" style="width:100%; padding:10px; border-radius:10px; border:none; background: rgba(16,185,129,0.15); color:#6ee7b7; font-weight:700; cursor:pointer;">
                            ✅ Başvuruyu Gönder
                        </button>
                        <button type="button" onclick="document.getElementById('basvuruForm').style.display='none'; document.querySelector('[onclick*=basvuruForm]').style.display=\'block\'"
                            style="width:100%; padding:8px; margin-top:6px; border-radius:8px; border:1.5px solid var(--border); background:transparent; color:var(--text-muted); cursor:pointer; font-size:0.82rem;">
                            İptal
                        </button>
                    </form>

                } else if (basvuru.Durum == "Beklemede") {
                    <div style="padding: 12px; border-radius: 10px; background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.25);">
                        <div style="font-weight:700; color:#fcd34d; font-size:0.88rem; margin-bottom:6px;">⏳ Başvurunuz İnceleniyor</div>
                        <div style="font-size:0.78rem; color:var(--text-muted); line-height:1.5;">Adminimiz en kısa sürede değerlendirecektir.</div>
                        <form asp-action="BasvuruIptal" method="post" style="margin-top:10px;">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; padding:7px; border-radius:8px; border:1px solid rgba(239,68,68,0.3); background:rgba(239,68,68,0.08); color:#fca5a5; font-size:0.8rem; cursor:pointer;">
                                Başvuruyu İptal Et
                            </button>
                        </form>
                    </div>

                } else if (basvuru.Durum == "Onaylandi") {
                    <div style="padding: 12px; border-radius: 10px; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.25);">
                        <div style="font-weight:700; color:#6ee7b7; font-size:0.88rem; margin-bottom:6px;">✅ Onaylandınız!</div>
                        <div style="font-size:0.78rem; color:var(--text-muted); line-height:1.5;">
                            Sipariş verirken "Askıda Yemek ile ücretsiz al" seçeneğini kullanabilirsiniz.
                            <strong style="color:#fcd34d;">Aylık limit: ₺500</strong>
                        </div>
                        @if (!string.IsNullOrEmpty(basvuru.AdminNotu)) {
                            <div style="margin-top:8px; font-size:0.76rem; color:var(--text-muted); font-style:italic;">
                                Admin notu: @basvuru.AdminNotu
                            </div>
                        }
                    </div>

                } else { // Reddedildi
                    <div style="padding: 12px; border-radius: 10px; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25);">
                        <div style="font-weight:700; color:#fca5a5; font-size:0.88rem; margin-bottom:6px;">❌ Başvurunuz Reddedildi</div>
                        @if (!string.IsNullOrEmpty(basvuru.AdminNotu)) {
                            <div style="font-size:0.78rem; color:var(--text-muted); margin-bottom:8px; line-height:1.5;">
                                Sebep: @basvuru.AdminNotu
                            </div>
                        }
                        <!-- Reddedilirse tekrar başvurabilir -->
                        <form asp-action="Basvur" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="width:100%; padding:8px; border-radius:8px; border:1px solid rgba(255,210,50,0.25); background:rgba(255,210,50,0.06); color:#fcd34d; font-size:0.82rem; cursor:pointer;">
                                🔄 Tekrar Başvur
                            </button>
                        </form>
                    </div>
                }
            </div>
        }

        @if (TempData["Mesaj"] != null) {
            <div style="margin-top:20px; padding: 12px 16px; border-radius: 10px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25); color: #6ee7b7; font-size: 0.85rem; text-align:left;">
                <i class="fa fa-check-circle" style="margin-right:6px;"></i> @TempData["Mesaj"]
            </div>
        }
        @if (TempData["Hata"] != null) {
            <div style="margin-top:20px; padding: 12px 16px; border-radius: 10px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.25); color: #fca5a5; font-size: 0.85rem; text-align:left;">
                <i class="fa fa-exclamation-circle" style="margin-right:6px;"></i> @TempData["Hata"]
            </div>
        }
    </div>

    <!-- ═══ Sağ: Düzenleme Formu ═══ -->
    <div class="profil-form-card">
        <div class="profil-form-header">
            <i class="fa fa-user-edit" style="color: var(--primary); font-size:1.1rem;"></i>
            <h2>Profil Bilgilerini Düzenle</h2>
        </div>

        <form asp-action="ProfilGuncelle" method="post">
            @Html.AntiForgeryToken()
            <div class="profil-form-body">

                <!-- Kişisel Bilgiler -->
                <div class="section-title"><i class="fa fa-id-card"></i> Kişisel Bilgiler</div>
                <div class="form-grid">
                    <div class="field">
                        <label>Ad</label>
                        <input type="text" name="Ad" value="@Model.Ad" required maxlength="50" />
                        <span class="field-error">@Html.ValidationMessage("Ad")</span>
                    </div>
                    <div class="field">
                        <label>Soyad</label>
                        <input type="text" name="Soyad" value="@Model.Soyad" required maxlength="50" />
                        <span class="field-error">@Html.ValidationMessage("Soyad")</span>
                    </div>
                </div>

                <!-- İletişim Bilgileri -->
                <div class="section-title"><i class="fa fa-address-book"></i> İletişim Bilgileri</div>
                <div class="form-grid">
                    <div class="field">
                        <label>E-posta <span style="font-size:0.72rem; color:var(--text-muted);">(değiştirilemez)</span></label>
                        <input type="email" value="@Model.Email" readonly />
                        <div class="hint">E-posta değişikliği için admin ile iletişime geçin.</div>
                    </div>
                    <div class="field">
                        <label>Telefon</label>
                        <input type="text" name="Telefon" value="@Model.Telefon" required maxlength="15" placeholder="05xx xxx xx xx" />
                        <span class="field-error">@Html.ValidationMessage("Telefon")</span>
                    </div>
                </div>

                <div class="form-grid full" style="margin-top:16px;">
                    <div class="field">
                        <label>Adres</label>
                        <input type="text" name="Adres" value="@Model.Adres" maxlength="250" placeholder="Teslimat adresiniz" />
                    </div>
                </div>

                <!-- Şifre Değişikliği -->
                <div class="section-title"><i class="fa fa-lock"></i> Şifre Değişikliği</div>
                <div class="sifre-toggle-section">
                    <button type="button" class="sifre-toggle-btn" onclick="toggleSifre()">
                        <i class="fa fa-key" id="sifre-icon"></i>
                        <span id="sifre-toggle-text">Şifremi değiştirmek istiyorum</span>
                    </button>
                    <div class="sifre-fields" id="sifreFields">
                        <div class="field">
                            <label>Mevcut Şifre</label>
                            <input type="password" name="MevcutSifre" id="MevcutSifre" placeholder="Mevcut şifrenizi giriniz" />
                            <span class="field-error">@Html.ValidationMessage("MevcutSifre")</span>
                        </div>
                        <div class="field">
                            <label>Yeni Şifre</label>
                            <input type="password" name="YeniSifre" placeholder="En az 6 karakter" minlength="6" />
                            <span class="field-error">@Html.ValidationMessage("YeniSifre")</span>
                        </div>
                        <div class="field">
                            <label>Yeni Şifre (Tekrar)</label>
                            <input type="password" name="YeniSifreTekrar" placeholder="Yeni şifrenizi tekrarlayın" />
                            <span class="field-error">@Html.ValidationMessage("YeniSifreTekrar")</span>
                        </div>
                    </div>
                </div>

            </div>

            <div class="profil-form-footer">
                <a asp-controller="Home" asp-action="Index" class="btn-cancel-link">İptal</a>
                <button type="submit" class="btn-save">
                    <i class="fa fa-floppy-disk"></i> Değişiklikleri Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script>
    function toggleSifre() {
        const fields = document.getElementById('sifreFields');
        const icon   = document.getElementById('sifre-icon');
        const text   = document.getElementById('sifre-toggle-text');
        const isOpen = fields.classList.toggle('open');

        icon.className  = isOpen ? 'fa fa-times' : 'fa fa-key';
        text.textContent = isOpen ? 'Vazgeç' : 'Şifremi değiştirmek istiyorum';

        // Kapatılınca input'ları temizle
        if (!isOpen) {
            ['MevcutSifre','YeniSifre','YeniSifreTekrar'].forEach(n => {
                const el = fields.querySelector(`[name="${n}"]`);
                if (el) el.value = '';
            });
        }
    }

    // Eğer şifre hata mesajı varsa otomatik aç
    @if (Html.ValidationMessage("MevcutSifre") != null && ViewData.ModelState["MevcutSifre"]?.Errors.Count > 0) {
        <text>document.addEventListener('DOMContentLoaded', () => toggleSifre());</text>
    }
</script>
}
