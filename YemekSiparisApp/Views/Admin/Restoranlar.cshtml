@model IEnumerable<YemekSiparisApp.Models.Entities.Restoran>
@{
    ViewData["Title"] = "Restoran Yönetimi";
    var sahipler = ViewBag.Sahipler as IEnumerable<YemekSiparisApp.Models.Entities.Kullanici>;
}

<div class="card" style="margin-bottom: 32px;">
    <div class="card-body">
        <h3 style="margin-bottom: 16px;">Yeni Restoran Ekle</h3>
        @if(sahipler != null && sahipler.Any()) {
            <form asp-action="RestoranEkle" method="post" style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr auto; gap: 16px; align-items: end;">
                <div class="form-group" style="margin-bottom: 0;">
                    <label>Restoran Adı</label>
                    <input type="text" name="Ad" required />
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                    <label>Açıklama</label>
                    <input type="text" name="Aciklama" />
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                    <label>Sahip Hesabı</label>
                    <select name="SahipKullaniciId" required>
                        @foreach(var s in sahipler) {
                            <option value="@s.KullaniciId">@s.Ad @s.Soyad (@s.Email)</option>
                        }
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Dakika</label>
                        <input type="number" name="TahminiTeslimatDakika" value="30" required />
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Min Sipariş</label>
                        <input type="number" name="MinSiparisUcreti" value="100" step="0.01" required />
                    </div>
                </div>
                <button type="submit" class="btn-primary" style="padding: 12px 24px;">➕ Ekle</button>
            </form>
        } else {
            <div class="alert alert-warning" style="margin: 0;">
                Sistemde boştaki bir 'RestoranSahibi' yetkisine sahip kullanıcı bulunmamaktadır. Lütfen önce "Kullanıcılar" menüsünden bir hesaba bu yetkiyi tanımlayın.
            </div>
        }
    </div>
</div>

<div class="card">
    <table class="action-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Restoran Adı</th>
                <th>Sahip</th>
                <th>Puan</th>
                <th>Genel Ciro</th>
                <th>Durum</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var r in Model) {
                <tr>
                    <td>#@r.RestoranId</td>
                    <td style="font-weight: 600;">@r.Ad</td>
                    <td>@(r.SahipKullanici != null ? r.SahipKullanici.Ad + " " + r.SahipKullanici.Soyad : "-")</td>
                    <td>⭐ @(r.Puan?.ToString("N2") ?? "-")</td>
                    <td>₺@r.ToplamCiro.ToString("N2")</td>
                    <td>
                        @if(r.IsActive) { <span class="badge badge-success">Yayında</span> }
                        else { <span class="badge badge-danger">Pasif</span> }
                    </td>
                    <td>
                        <form asp-action="RestoranDurumDegistir" method="post" style="margin:0;">
                            <input type="hidden" name="id" value="@r.RestoranId" />
                            @if(r.IsActive) {
                                <button type="submit" class="btn-outline-sm" style="color: #ef4444; border-color: rgba(239,68,68,0.5);">Kapat</button>
                            } else {
                                <button type="submit" class="btn-outline-sm" style="color: #6ee7b7; border-color: rgba(16,185,129,0.5);">Aç</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
